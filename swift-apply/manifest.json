{
  "manifest_version": 3,
  "name": "SwiftApply",
  "version": "2.3.0",
  "description": "Smart job application assistant — reads job postings, scores them, tailors your CV, and helps you apply faster.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://*.indeed.com/*",
    "https://*.glassdoor.com/*",
    "https://*.hiring.cafe/*",
    "https://*.pracuj.pl/*",
    "https://generativelanguage.googleapis.com/*",
    "http://localhost:11434/*",
    "https://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/templates/*.docx", "lib/docx.bundle.mjs", "lib/jspdf.bundle.mjs"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content/content.js"],
      "css": ["sidebar/sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    },
    "default_title": "SwiftApply"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
